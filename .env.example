# ==================== FRONTEND RUNTIME ENV ====================
# Local: copiar este archivo como .env y ejecutar `pnpm start`.
# Si quieres pre-generarlo manualmente: `pnpm env:generate`.
# Dokploy SSR: define estas variables en el panel.
# No guardes secretos en el frontend.

# API Backend base (recomendado incluir /api/v1)
API_URL=http://localhost:8080/api/v1

# Usuario administrador con acceso completo
ADMIN_USERNAME=admin

# Base path opcional cuando el front vive bajo subruta (ej: /trazabilidad/)
# En local normalmente usar '/'
APP_BASE_PATH=/
