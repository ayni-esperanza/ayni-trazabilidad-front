# ==================== FRONTEND ENV EXAMPLE ====================
# Este archivo sirve como plantilla de variables para despliegue.
# El valor de API_URL debe inyectarse en public/env.js.
# Ejemplo deploy:
#   cp .env.example .env
#   # set API_URL en .env
#   # generar public/env.js antes de ng build

# API Backend base (debe incluir /api/v1)
API_URL=http://localhost:8080/api/v1

# Usuario administrador habilitado para ver todos los submodulos
ADMIN_USERNAME=admin
