# ==================== FRONTEND ENV EXAMPLE ====================
# Copiar como .env y ajustar antes de ejecutar start/build/test.
# El script tools/generate-environment.cjs genera src/environments/*.ts
# usando exclusivamente estas variables.

# API Backend base (debe incluir /api/v1)
API_URL=http://localhost:8080/api/v1

# Usuario administrador con acceso completo
ADMIN_USERNAME=admin
